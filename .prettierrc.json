{
	"overrides": [
		{
			"files": "./packages/crawlers/**/*.ts",
			"options": {
				"printWidth": 144
			}
		}
	],
	"useTabs": true,
	"tabWidth": 4,
	"arrowParens": "avoid",
	"bracketSameLine": true,
	"bracketSpacing": false,
	"embeddedLanguageFormatting": "auto",
	"endOfLine": "lf",
	"objectWrap": "collapse",
	"proseWrap": "always",
	"quoteProps": "consistent",
	"semi": false,
	"trailingComma": "none",
	"singleQuote": false
}
