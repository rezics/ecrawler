{
	"name": "@ecrawler/collector",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "tsx --env-file=.env.production ./src/main.ts",
		"dev": "tsx --env-file=.env.development ./src/main.ts",
		"generate": "cd ./src/database && drizzle-kit generate",
		"migrate": "cd ./src/database && drizzle-kit migrate"
	},
	"dependencies": {
		"@ecrawler/api": "workspace:*",
		"@ecrawler/core": "workspace:*",
		"@ecrawler/schemas": "workspace:*",
		"drizzle-kit": "~0.31.8"
	},
	"exports": {
		"./*": "./src/*"
	}
}
