{
	"name": "@ecrawler/worker",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "tsx --env-file=.env.production ./src/main.ts",
		"dev": "tsx --env-file=.env.development ./src/main.ts"
	},
	"exports": {
		"./*": "./src/*"
	},
	"dependencies": {
		"@ecrawler/api": "workspace:*",
		"@ecrawler/schemas": "workspace:*",
		"@ecrawler/worker-bqgl": "workspace:^",
		"@ecrawler/worker-dummy": "workspace:^",
		"@ecrawler/worker-qidian": "workspace:^"
	},
	"workspaces": [
		"./implementations/*"
	]
}
