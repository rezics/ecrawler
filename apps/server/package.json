{
  "name": "@ecrawler/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "yarn workspace @ecrawler/server run -T tsx --env-file-if-exists=.env.production ./src/main.ts",
    "dev": "yarn workspace @ecrawler/server run -T tsx --env-file-if-exists=.env.development ./src/main.ts",
    "generate": "cd ./src/database && drizzle-kit generate",
    "migrate": "cd ./src/database && drizzle-kit migrate",
    "build:bundle": "yarn run -T esbuild ./src/main.ts --bundle --keep-names --minify --platform=node --target=node24 --format=esm --outfile=./dist/main.mjs --banner:js='import { createRequire } from \"node:module\"; const require = createRequire(import.meta.url);'",
    "build:podman": "podman build . -t ecrawler:server --network=host --format=oci --output=type=tar,dest=./dist/podman.tar",
    "build": "yarn run build:bundle && yarn run build:podman"
  },
  "dependencies": {
    "@ecrawler/api": "workspace:*",
    "@ecrawler/schemas": "workspace:*",
    "drizzle-kit": "beta",
    "drizzle-orm": "beta",
    "postgres": "^3.4.8"
  },
  "exports": {
    "./*": "./src/*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15"
  }
}
